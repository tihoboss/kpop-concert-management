{
  "name": "kpop-concert-management",
  "version": "1.0.0",
  "description": "Система управления K-POP концертами",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:selenium": "node tests/selenium/kpopTests.js",
    "test:cucumber": "cucumber-js tests/features/*.feature --require tests/step_definitions/*.js --format progress --format json:reports/cucumber_report.json",
    "test:cucumber:verbose": "cucumber-js tests/features/*.feature --require tests/step_definitions/*.js --format progress",
    "test:all": "npm run test && npm run test:selenium && npm run test:cucumber"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "chromedriver": "^112.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "selenium-webdriver": "^4.33.0",
    "webdriverio": "^7.40.0"
  }
}